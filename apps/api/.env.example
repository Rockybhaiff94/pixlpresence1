# Backend Server Port
PORT=3000

# Client URL (Frontend)
CLIENT_URL=http://localhost:3001

# Session Secret (Generate a random string for production)
SESSION_SECRET=super_secret_discord_rpc_key

# Discord OAuth2 Credentials
# Go to https://discord.com/developers/applications to create an app
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here
DISCORD_CALLBACK_URL=http://localhost:3000/auth/discord/callback

# Database Connection (Default uses local PostgreSQL)
# Example: postgresql://postgres:password@localhost:5432/discord_rpc
DATABASE_URL=postgresql://user:password@localhost:5432/discord_rpc
